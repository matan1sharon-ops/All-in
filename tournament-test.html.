<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <style>
        body { font-family: sans-serif; margin: 0; background: #1a1a1a; color: white; display: flex; flex-direction: column; height: 100vh; }
        #table-container { flex: 1; overflow: auto; background: white; color: black; padding: 5px; }
        table { width: 100%; border-collapse: collapse; table-layout: fixed; font-size: 12px; }
        th, td { border: 1px solid black; text-align: center; height: 22px; padding: 0; }
        .header { background: #eee; font-weight: bold; font-size: 10px; }
        .active { background: #fff9c4; border: 2px solid orange !important; }
        
        /* The "X" Box with diagonal lines */
        .x-box {
            background: linear-gradient(to top right, transparent 48%, black 48%, black 52%, transparent 52%),
                        linear-gradient(to top left, transparent 48%, black 48%, black 52%, transparent 52%);
        }

        #pad { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; padding: 10px; background: #2a2a2a; }
        button { padding: 15px 0; font-size: 18px; font-weight: bold; border-radius: 5px; border: none; background: #444; color: white; }
        button:active { background: orange; }
    </style>
</head>
<body>

<div id="table-container">
    <table>
        <thead>
            <tr class="header">
                <th style="width:30px">end</th>
                <th colspan="3">arrows</th>
                <th>sum</th>
                <th>add</th>
                <th>10-X</th>
                <th>X</th>
            </tr>
        </thead>
        <tbody id="sheet-body"></tbody>
    </table>
</div>

<div id="pad">
    <button onclick="add('X')">X</button><button onclick="add(10)">10</button><button onclick="add(9)">9</button><button onclick="add(8)">8</button>
    <button onclick="add(7)">7</button><button onclick="add(6)">6</button><button onclick="add(5)">5</button><button onclick="add(4)">4</button>
    <button onclick="add(3)">3</button><button onclick="add(2)">2</button><button onclick="add(1)">1</button><button onclick="add('M')">M</button>
</div>

<script>
    let scores = [];
    const body = document.getElementById('sheet-body');

    function render() {
        let html = '';
        let runningTotal = 0;
        for(let e=1; e<=12; e++) {
            let start = (e-1)*6;
            let a = [0,1,2,3,4,5].map(i => scores[start+i] || "");
            
            // Calc Math
            let s1 = a.slice(0,3).reduce((s,v)=>s+(v==='X'||v===10?10:v==='M'?0:Number(v)||0),0);
            let s2 = a.slice(3,6).reduce((s,v)=>s+(v==='X'||v===10?10:v==='M'?0:Number(v)||0),0);
            let endTotal = (a[2]!=="" && a[5]!=="") ? s1 + s2 : "";
            if(endTotal !== "") runningTotal += endTotal;
            
            let c10x = a.filter(v => v===10 || v==='X').length;
            let cx = a.filter(v => v==='X').length;

            html += `
                <tr>
                    <td rowspan="2">${e}</td>
                    <td id="cell-${start}">${a[0]}</td><td id="cell-${start+1}">${a[1]}</td><td id="cell-${start+2}">${a[2]}</td>
                    <td>${a[2]!==""?s1:""}</td>
                    <td rowspan="2">${runningTotal || ""}</td>
                    <td rowspan="2">${a[5]!==""?c10x:""}</td>
                    <td rowspan="2">${a[5]!==""?cx:""}</td>
                </tr>
                <tr>
                    <td id="cell-${start+3}">${a[3]}</td><td id="cell-${start+4}">${a[4]}</td><td id="cell-${start+5}">${a[5]}</td>
                    <td class="${endTotal!==""?'x-box':''}">${endTotal}</td>
                </tr>
            `;
        }
        body.innerHTML = html;
        let next = document.getElementById('cell-'+scores.length);
        if(next) {
            next.classList.add('active');
            next.scrollIntoView({behavior:'smooth', block:'center'});
        }
    }

    function add(v) {
        if(scores.length < 72) {
            scores.push(v);
            render();
        }
    }
    render();
</script>
</body>
</html>
